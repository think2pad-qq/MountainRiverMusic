---
import type { CollectionEntry } from 'astro:content';

interface Props {
  work: CollectionEntry<'works'>;
}

const { work } = Astro.props;
const { data } = work;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const isAlbum = data.type === 'album';
const trackCount = data.tracks?.length || 0;
const href = `${base}${isAlbum ? 'albums' : 'works'}/${work.id.replace(/\.md$/, '')}/`;
---

<article class="work-card">
  <a href={href} class="work-cover" aria-label={`查看${isAlbum ? '专辑' : '作品'}：${data.title}`}>
    <img src={data.cover} alt={`${data.title} 封面`} loading="lazy" />
  </a>
  <div class="work-card-body">
    <div class="work-meta">
      <span>{data.year}</span>
      {isAlbum
        ? <span>{trackCount} 首</span>
        : data.duration && <span>{data.duration}</span>
      }
    </div>
    <h3><a href={href}>{data.title}</a></h3>
    {data.subtitle && <p>{data.subtitle}</p>}
    <div class="tag-row">
      {data.style.map((tag) => <span>{tag}</span>)}
    </div>
  </div>
</article>
