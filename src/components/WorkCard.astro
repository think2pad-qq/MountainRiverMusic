---
import type { CollectionEntry } from 'astro:content';

interface Props {
  work: CollectionEntry<'works'>;
}

const { work } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const href = `${base}works/${work.id.replace(/\.md$/, '')}/`;
---

<article class="work-card">
  <a href={href} class="work-cover" aria-label={`查看作品：${work.data.title}`}>
    <img src={work.data.cover} alt={`${work.data.title} 封面`} loading="lazy" />
  </a>
  <div class="work-card-body">
    <div class="work-meta">
      <span>{work.data.year}</span>
      <span>{work.data.duration}</span>
    </div>
    <h3><a href={href}>{work.data.title}</a></h3>
    {work.data.subtitle && <p>{work.data.subtitle}</p>}
    <div class="tag-row">
      {work.data.style.map((tag) => <span>{tag}</span>)}
    </div>
  </div>
</article>
