---
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const navItems = [
  { href: base, label: '首页' },
  { href: `${base}works/`, label: '作品' },
  { href: `${base}about/`, label: '关于' },
  { href: `${base}press-kit/`, label: 'Press Kit' }
];
---

<header class="site-header">
  <a class="brand" href={base} aria-label="山川有乐首页">
    <img class="brand-icon" src="/MountainRiverMusic/images/header-icon.png" alt="" aria-hidden="true" />
    <span>山川有乐</span>
  </a>
  <nav class="site-nav" aria-label="主导航">
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>
</header>
