---
import SiteFooter from '@/components/SiteFooter.astro';
import SiteHeader from '@/components/SiteHeader.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = '普洁工作室 - 原创音乐与声音叙事',
  description = '普洁工作室是一个面向原创音乐、配乐、声音叙事和创作笔记的专业音乐人网站。',
  image = 'https://upload.wikimedia.org/wikipedia/commons/thumb/e/e1/Mountain_landscape_with_a_river_close_to_Leh_Ladakh.jpg/1280px-Mountain_landscape_with_a_river_close_to_Leh_Ladakh.jpg'
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="普洁工作室" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <title>{title}</title>
  </head>
  <body>
    <SiteHeader />
    <main>
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f7f3ee;
    --surface: #fffaf3;
    --ink: #202124;
    --muted: #65625b;
    --line: rgba(32, 33, 36, 0.13);
    --green: #2d6a55;
    --amber: #c58a31;
    --red: #a84b3f;
    --shadow: 0 20px 60px rgba(32, 33, 36, 0.12);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      "Microsoft YaHei", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--ink);
    line-height: 1.65;
  }

  img,
  audio {
    max-width: 100%;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  a:hover {
    color: var(--green);
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 18px clamp(20px, 5vw, 72px);
    border-bottom: 1px solid var(--line);
    background: rgba(247, 243, 238, 0.9);
    backdrop-filter: blur(14px);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 800;
    letter-spacing: 0;
  }

  .brand-icon {
    display: inline-grid;
    width: 28px;
    height: 28px;
    place-items: center;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: clamp(12px, 3vw, 28px);
    color: var(--muted);
    font-size: 15px;
  }

  main {
    min-height: 70vh;
  }

  .section {
    padding: clamp(56px, 8vw, 104px) clamp(20px, 5vw, 72px);
  }

  .section-inner {
    width: min(1120px, 100%);
    margin: 0 auto;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 28px;
    margin-bottom: 32px;
  }

  .section-heading h2 {
    margin: 0;
    font-size: clamp(28px, 4vw, 48px);
    line-height: 1.15;
    letter-spacing: 0;
  }

  .section-heading p {
    max-width: 460px;
    margin: 0;
    color: var(--muted);
  }

  .eyebrow {
    display: block;
    color: var(--red);
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .button-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 18px;
    border: 1px solid var(--ink);
    border-radius: 999px;
    background: var(--ink);
    color: white;
    font-weight: 700;
  }

  .button-link:hover {
    border-color: var(--green);
    background: var(--green);
    color: white;
  }

  .button-link.secondary {
    background: transparent;
    color: var(--ink);
  }

  .button-link.secondary:hover {
    background: var(--green);
    color: white;
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }

  .work-card {
    display: grid;
    grid-template-columns: 180px minmax(0, 1fr);
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
    box-shadow: 0 10px 34px rgba(32, 33, 36, 0.08);
  }

  .work-cover {
    display: block;
    min-height: 190px;
    background: #d8d2c8;
  }

  .work-cover {
    position: relative;
  }

  .work-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .work-badge {
    position: absolute;
    top: 8px;
    right: 8px;
    padding: 2px 7px;
    border-radius: 4px;
    background: #5c7a6b;
    color: #fff;
    font-size: 11px;
    font-weight: 500;
    line-height: 1.4;
  }

  .work-card--album {
    border-left: 3px solid #5c7a6b;
  }

  .work-card-body {
    padding: 22px;
  }

  .work-meta {
    display: flex;
    gap: 12px;
    margin-bottom: 10px;
    color: var(--muted);
    font-size: 13px;
  }

  .work-card h3 {
    margin: 0 0 8px;
    font-size: 22px;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .work-card p {
    margin: 0 0 16px;
    color: var(--muted);
    font-size: 15px;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag-row span {
    padding: 4px 9px;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--green);
    font-size: 13px;
    font-weight: 700;
  }

  .audio-player {
    display: grid;
    gap: 16px;
    padding: 20px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.35);
    border-bottom: 1px solid rgba(255, 255, 255, 0.35);
  }

  .audio-player strong {
    display: inline-block;
    margin-right: 10px;
    font-size: 18px;
  }

  .audio-player .duration {
    color: rgba(255, 255, 255, 0.78);
    font-size: 14px;
  }

  .audio-player audio {
    width: min(520px, 100%);
  }

  .site-footer {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    padding: 28px clamp(20px, 5vw, 72px);
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 14px;
  }

  .site-footer p {
    margin: 0;
  }

  @media (max-width: 760px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
      gap: 12px;
      padding: 16px 20px;
    }

    .site-nav {
      width: 100%;
      justify-content: space-between;
      gap: 10px;
      font-size: 14px;
    }

    .section-heading {
      align-items: flex-start;
      flex-direction: column;
    }

    .work-grid,
    .work-card {
      grid-template-columns: 1fr;
    }

    .work-cover {
      aspect-ratio: 16 / 9;
      min-height: auto;
    }

    .site-footer {
      flex-direction: column;
    }
  }
</style>
