---
import { getCollection } from 'astro:content';
import AudioPlayer from '@/components/AudioPlayer.astro';
import WorkCard from '@/components/WorkCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

const works = await getCollection('works');

// 首页封面图：从 useAsHeroCover 作品中选最新的
const heroWorks = works.filter((w) => w.data.useAsHeroCover).sort((a, b) => b.data.year - a.data.year);
const heroImage = heroWorks.length > 0 ? heroWorks[0].data.cover : "https://pub-87eb1f986b9944959ac542319a76a55e.r2.dev/hero-default.webp";

// 首页播放器：从 useAsHeroPlayer 作品中选最新的
const playerWorks = works.filter((w) => w.data.useAsHeroPlayer).sort((a, b) => b.data.year - a.data.year);
const playerWork = playerWorks.length > 0 ? playerWorks[0] : null;

// 近期作品列表：只展示 showOnHome 的作品
const homeWorks = works.filter((w) => w.data.showOnHome);

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout>
  <section class="hero">
    <img src={heroImage} alt="山川与河流的辽阔风景" />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <span class="eyebrow">Official Site</span>
      <h1>普洁工作室</h1>
      <p>普在尘泥，落脚于万象喧嚣；孤守自洁，归真于音符方寸。
把在俗世中游历的灵魂，留在属于山川与乐音的自留地。</p>
      <div class="hero-actions">
        <a class="button-link" href={`${base}works/`}>进入作品库</a>
        <a class="button-link secondary hero-secondary" href={`${base}about/`}>了解音乐人</a>
      </div>
      {playerWork && <AudioPlayer title={playerWork.data.title} audio={playerWork.data.audio} duration={playerWork.data.duration} />}
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Works</span>
          <h2>近期作品</h2>
        </div>

      </div>
      <div class="work-grid">
        {homeWorks.map((work) => <WorkCard work={work} />)}
      </div>
    </div>
  </section>

  <section class="section statement">
    <div class="section-inner statement-inner">
      <span class="eyebrow">Statement</span>
      <h2>声音在此流淌，也在此共享。</h2>
      <p>
        本站展示的部分非商业作品遵循 Creative Commons（CC协议）开放使用。
        如果你是独立播客主播、视频UP主或学生导演，欢迎在注明出处的前提下，让这些声音成为你作品的一部分。商业使用请提前联系授权。
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: 78svh;
    overflow: hidden;
    display: grid;
    align-items: center;
    padding: clamp(72px, 10vw, 112px) clamp(20px, 5vw, 72px);
    color: white;
  }

  .hero > img,
  .hero-overlay {
    position: absolute;
    inset: 0;
  }

  .hero > img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    background:
      linear-gradient(90deg, rgba(15, 18, 18, 0.82), rgba(15, 18, 18, 0.43) 48%, rgba(15, 18, 18, 0.18)),
      linear-gradient(0deg, rgba(15, 18, 18, 0.3), rgba(15, 18, 18, 0.06));
  }

  .hero-content {
    position: relative;
    width: min(760px, 100%);
    display: grid;
    gap: 24px;
  }

  .hero h1 {
    margin: 0;
    font-size: clamp(56px, 9vw, 118px);
    line-height: 0.96;
    letter-spacing: 0;
  }

  .hero p {
    width: min(620px, 100%);
    margin: 0;
    color: rgba(255, 255, 255, 0.88);
    font-size: clamp(18px, 2vw, 24px);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .hero-secondary {
    border-color: rgba(255, 255, 255, 0.76);
    color: white;
  }

  .statement {
    background: #202124;
    color: white;
  }

  .statement-inner {
    display: grid;
    gap: 18px;
  }

  .statement h2 {
    max-width: 900px;
    margin: 0;
    font-size: clamp(30px, 5vw, 64px);
    line-height: 1.08;
    letter-spacing: 0;
  }

  .statement p {
    max-width: 680px;
    margin: 0;
    color: rgba(255, 255, 255, 0.76);
    font-size: 18px;
  }

  @media (max-width: 760px) {
    .hero {
      min-height: 74svh;
      align-items: end;
    }
  }
</style>
