---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('works');
  return entries
    .filter(e => e.data.type === 'album')
    .map(e => ({
      params: { slug: e.id.replace(/\.md$/, '') },
      props: { entry: e }
    }));
}

const { entry } = Astro.props;
const { title, subtitle, year, style, tracks, cover } = entry.data;
const trackCount = tracks?.length || 0;
const { Content } = await render(entry);
---

<BaseLayout title={`${title} - 普洁工作室`} description={subtitle ?? `${title} 的专辑详情。`}>
  <article class="album-detail">
    <section class="detail-hero">
      <img src={cover} alt={`${title} 封面`} />
      <div class="detail-copy">
        <span class="eyebrow">{year} / {trackCount} 首</span>
        <h1>{title}</h1>
        {subtitle && <p>{subtitle}</p>}
        <div class="tag-row">
          {style?.map((tag) => <span>{tag}</span>)}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-inner">
        <h2 class="track-section-title">曲目</h2>
        <ol class="track-list">
          {tracks?.map((track, i) => (
            <li class="track-item" data-index={i}>
              <span class="track-num">{i + 1}</span>
              <div class="track-info">
                <span class="track-title">{track.title}</span>
                {track.duration && <span class="track-duration">{track.duration}</span>}
              </div>
              <button class="track-play-btn" data-index={i} aria-label="播放">{track.audio ? '▶' : ''}</button>
              {track.audio && <audio src={track.audio} preload="none" data-index={i} />}
            </li>
          ))}
        </ol>

        {entry.body && (
          <div class="album-description prose">
            <h2>关于这张专辑</h2>
            <Content />
          </div>
        )}
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .album-detail {
    max-width: 720px;
    margin: 0 auto;
    padding-bottom: 64px;
  }

  .detail-hero {
    display: grid;
    grid-template-columns: minmax(280px, 0.8fr) minmax(0, 1fr);
    gap: 32px;
    padding: 48px 0;
  }

  .detail-hero img {
    width: 100%;
    border-radius: 8px;
  }

  .detail-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 8px;
  }

  .eyebrow {
    font-size: 13px;
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
  }

  .track-section-title {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 16px;
  }

  .track-list {
    list-style: none;
    padding: 0;
    margin: 0 0 40px;
  }

  .track-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid var(--color-border);
    cursor: default;
    transition: background 0.15s ease;
  }

  .track-item:hover {
    background: var(--surface-hover, rgba(0,0,0,0.02));
  }

  .track-item:last-child {
    border-bottom: none;
  }

  .track-item--playing {
    background: rgba(92, 122, 107, 0.06);
  }

  .track-num {
    width: 24px;
    font-size: 13px;
    color: var(--color-text-tertiary);
    text-align: center;
    flex-shrink: 0;
  }

  .track-info {
    flex: 1;
    min-width: 0;
  }

  .track-title {
    display: block;
    font-size: 15px;
    font-weight: 500;
  }

  .track-duration {
    font-size: 12px;
    color: var(--color-text-tertiary);
    margin-top: 2px;
  }

  .track-play-btn {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    background: transparent;
    color: var(--color-text);
    font-size: 14px;
    cursor: pointer;
    flex-shrink: 0;
    transition: all 0.15s ease;
  }

  .track-play-btn:hover {
    border-color: #5c7a6b;
    background: rgba(92, 122, 107, 0.08);
    color: #5c7a6b;
  }

  .track-play-btn--playing {
    border-color: #5c7a6b;
    background: #5c7a6b;
    color: #fff;
  }

  .album-description {
    margin-top: 32px;
  }
</style>

<script>
  (function() {
    const list = document.querySelector('.track-list')
    if (!list) return

    const items = list.querySelectorAll('.track-item')
    const audios: HTMLAudioElement[] = []
    const btns: HTMLButtonElement[] = []

    items.forEach((item) => {
      const audio = item.querySelector('audio')
      const btn = item.querySelector<HTMLButtonElement>('.track-play-btn')
      if (!audio || !btn) return

      const index = audios.length
      audios.push(audio)
      btns.push(btn)

      btn.addEventListener('click', () => {
        if (!audio.paused) {
          audio.pause()
          return
        }
        // Pause all others
        audios.forEach((a, j) => {
          if (j !== index) { a.pause(); a.currentTime = 0 }
        })
        audio.play()
      })

      audio.addEventListener('play', () => {
        items.forEach((el, j) => el.classList.toggle('track-item--playing', j === index))
        btns.forEach((b, j) => b.classList.toggle('track-play-btn--playing', j === index))
        btn.textContent = '⏸'
      })

      audio.addEventListener('pause', () => {
        btn.classList.remove('track-play-btn--playing')
        btn.textContent = '▶'
      })

      audio.addEventListener('ended', () => {
        items.forEach((el) => el.classList.remove('track-item--playing'))
        btn.classList.remove('track-play-btn--playing')
        btn.textContent = '▶'
      })
    })
  })()
</script>
