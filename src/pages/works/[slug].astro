---
import { getCollection, render } from 'astro:content';
import AudioPlayer from '@/components/AudioPlayer.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const works = await getCollection('works');
  return works.map((work) => ({
    params: { slug: work.id.replace(/\.md$/, '') },
    props: { work }
  }));
}

const { work } = Astro.props;
const { Content } = await render(work);
---

<BaseLayout title={`${work.data.title} - 山川有乐`} description={work.data.subtitle ?? `${work.data.title} 的作品详情。`}>
  <article class="work-detail">
    <section class="detail-hero">
      <img src={work.data.cover} alt={`${work.data.title} 封面`} />
      <div class="detail-copy">
        <span class="eyebrow">{work.data.year} / {work.data.duration}</span>
        <h1>{work.data.title}</h1>
        {work.data.subtitle && <p>{work.data.subtitle}</p>}
        <div class="tag-row">
          {work.data.style.map((tag) => <span>{tag}</span>)}
        </div>
        <AudioPlayer title={work.data.title} audio={work.data.audio} duration={work.data.duration} />
      </div>
    </section>

    <section class="section">
      <div class="section-inner prose">
        <Content />
        {work.data.externalLinks && (
          <div class="external-links">
            <h2>外部链接</h2>
            {work.data.externalLinks.bilibili && <a href={work.data.externalLinks.bilibili}>Bilibili</a>}
            {work.data.externalLinks.netease && <a href={work.data.externalLinks.netease}>网易云音乐</a>}
            {work.data.externalLinks.soundcloud && <a href={work.data.externalLinks.soundcloud}>SoundCloud</a>}
          </div>
        )}
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .detail-hero {
    display: grid;
    grid-template-columns: minmax(320px, 0.9fr) minmax(0, 1.1fr);
    min-height: 68svh;
    background: #202124;
    color: white;
  }

  .detail-hero > img {
    width: 100%;
    height: 100%;
    min-height: 520px;
    object-fit: cover;
  }

  .detail-copy {
    display: grid;
    align-content: center;
    gap: 22px;
    padding: clamp(36px, 6vw, 80px);
  }

  h1 {
    margin: 0;
    font-size: clamp(44px, 7vw, 86px);
    line-height: 1;
    letter-spacing: 0;
  }

  .detail-copy p {
    max-width: 620px;
    margin: 0;
    color: rgba(255, 255, 255, 0.78);
    font-size: 20px;
  }

  .prose {
    max-width: 760px;
    font-size: 18px;
  }

  .prose :global(p) {
    color: var(--muted);
  }

  .external-links {
    margin-top: 42px;
    padding-top: 28px;
    border-top: 1px solid var(--line);
  }

  .external-links h2 {
    margin: 0 0 14px;
  }

  .external-links a {
    display: inline-flex;
    margin-right: 12px;
    color: var(--green);
    font-weight: 800;
  }

  @media (max-width: 820px) {
    .detail-hero {
      grid-template-columns: 1fr;
    }

    .detail-hero > img {
      aspect-ratio: 16 / 10;
      min-height: auto;
    }
  }
</style>
